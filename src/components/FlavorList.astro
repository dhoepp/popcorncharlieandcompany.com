---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const flavors = Array.from({ length: 28 }, (_, i) => {
  const suffix = i === 0 ? "" : String(i + 1);
  return `${base}/images/PopcornCharlie_FLAVORLIST${suffix}.jpg`;
});
---

<section class="flavor-list">
  <div class="flavor-images">
    {flavors.map((src, i) => <img src={src} alt={`Flavor ${i + 1}`} />)}
  </div>
</section>

<style>
  .flavor-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 96px;
  }

  .flavor-images {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  .flavor-images img {
    width: 612px;
    max-width: 100%;
    height: auto;
  }
</style>
