---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const flavors = Array.from({ length: 28 }, (_, i) => {
  const suffix = i === 0 ? "" : String(i + 1);
  return `${base}/images/PopcornCharlie_FLAVORLIST${suffix}.jpg`;
});

const [first] = flavors;
---

<section class="flavor-list">
  <button class="flavor-trigger" aria-label="View full flavor list">
    <img src={first} alt="Flavor 1" />
  </button>
</section>

<div class="flavor-modal" id="flavorModal" aria-modal="true" role="dialog" aria-label="Full flavor list">
  <div class="flavor-modal-backdrop"></div>
  <div class="flavor-modal-content">
    <button class="flavor-modal-close" aria-label="Close">&times;</button>
    <div class="flavor-modal-images">
      {flavors.map((src, i) => <img src={src} alt={`Flavor ${i + 1}`} />)}
    </div>
  </div>
</div>

<script>
  const trigger = document.querySelector('.flavor-trigger') as HTMLButtonElement;
  const modal = document.getElementById('flavorModal') as HTMLElement;
  const backdrop = modal.querySelector('.flavor-modal-backdrop') as HTMLElement;
  const closeBtn = modal.querySelector('.flavor-modal-close') as HTMLButtonElement;

  function openModal() {
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  trigger.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

<style>
  .flavor-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 96px;
  }

  .flavor-trigger {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .flavor-trigger img {
    width: 612px;
    max-width: 100%;
    height: auto;
    display: block;
    transition: filter 0.2s;
  }

  .flavor-trigger:hover img {
    filter: brightness(0.8);
  }

  /* Modal */
  .flavor-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
  }

  .flavor-modal.open {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .flavor-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }

  .flavor-modal-content {
    position: relative;
    z-index: 101;
    background: white;
    width: 90%;
    max-width: 680px;
    max-height: 90vh;
    overflow-y: auto;
    margin-top: 32px;
    border-radius: 8px;
    padding: 48px 24px 24px;
  }

  .flavor-modal-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .flavor-modal-close:hover {
    opacity: 1;
  }

  .flavor-modal-images {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .flavor-modal-images img {
    width: 100%;
    height: auto;
  }
</style>
