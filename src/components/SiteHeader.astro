---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="site-header">
  <a href="/">
    <img
      src={`${base}/images/PopcornCharlie_ROUND_LOGO.svg`}
      alt='"Popcorn Charlie" & Company'
      width="144"
      height="144"
    />
  </a>
  <nav class="site-nav">
    <!-- <a href="#about">About</a> -->
    <a href="#special-orders">About</a>
    <a href="#contact">Store Info</a>
    <a href="#map">Find us!</a>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px;
    gap: 12px;
  }

  .site-nav {
    display: flex;
    gap: 24px;
  }

  .site-nav a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    transition: opacity 0.15s;
  }

  .site-nav a:hover {
    opacity: 0.65;
  }
</style>
