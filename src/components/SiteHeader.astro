    <img src={`${base}/images/PopcornCharlie_ROUND_LOGO.svg`} alt='"Popcorn Charlie" & Company' width="144" height="144" />
  </a>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: center;
    padding: 16px;
  }
</style>
