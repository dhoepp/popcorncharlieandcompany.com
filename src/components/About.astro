---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="about">

  <div class="contact-row" id="contact">
    <h2>Contact Us</h2>

    <div class="contact-info">
      <h4>"Popcorn Charlie" and Company</h4>
      <p>3601 North Division Street, Davenport, Iowa 52806, United States</p>
      <a href="tel:5633889555">563-388-9555</a>
    </div>

    <div class="contact-hours">
      <h4>Hours</h4>
      <p>Open W-F: 10:00 am – 06:00 pm (10-5 Saturday)</p>
    </div>

    <!-- <form class="contact-form">
      <h4>We're Here to Help!</h4>
      <input type="text" placeholder="Name*" required />
      <input type="email" placeholder="Email*" required />
      <textarea rows="4" placeholder="Message*" required></textarea>
      <button type="submit">Send</button>
    </form> -->
  </div>

  <div class="bottom-row">
    <img src={`${base}/images/BowtieCharlie.jpg`} alt="Popcorn Charlie" />

    <div class="special-orders" id="special-orders">
      <h4>Personalized Service:</h4>
      <p>
        We also take special requests. If you want a flavor that is out of season
        or only available upon request, we will make it for you! The only catch
        is: you have to meet a minimum purchase amount:
      </p>
      <ul>
        <li>$20 for Savory Flavors</li>
        <li>$30 for Candied Flavors</li>
        <li>$35 for Candied+ Flavors</li>
        <li>$40 for Premium Candied Flavors</li>
      </ul>

      <h4>Committed to Quality</h4>
      <p><!-- content to be filled in --></p>

      <h4>100% Satisfaction Guaranteed</h4>
      <p>
        Our popcorn is guaranteed fresh for one month after the packaged date. We
        want you to be completely satisfied, so if you experience any issues with
        the product, please contact us right away so we can address the problem.
      </p>
    </div>
  </div>

</section>

<style>
  .contact-row {
    padding: 48px 32px 24px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-row h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .contact-row h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 20px 0 6px;
  }

  .contact-row p {
    line-height: 1.65;
  }

  .contact-info a {
    display: inline-block;
    margin-top: 6px;
    font-weight: 600;
  }

  .bottom-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    padding: 24px 32px 48px;
    gap: 32px;
  }

  .bottom-row > img {
    width: 300px;
    height: auto;
    margin: 0 auto;
  }

  .special-orders {
    width: 50%;
  }

  .special-orders h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 20px 0 6px;
  }

  .special-orders p,
  .special-orders li {
    line-height: 1.65;
  }

  .special-orders ul {
    padding-left: 20px;
    margin-top: 8px;
  }

  .special-orders li {
    margin-bottom: 4px;
  }
</style>
