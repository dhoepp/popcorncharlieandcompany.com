---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="about">
  <div class="contact-row" id="contact">
    <div class="contact-info">
      <h4 class="name">"Popcorn Charlie" and Company</h4>
      <p>
        3601 North Division Street<br /> Davenport, Iowa 52806<br /> United States
        of America
      </p>
      <a href="tel:5633889555">563-388-9555</a>
    </div>

    <div class="contact-hours">
      <h4>Hours</h4>
      <ul class="hours-list">
        <li><span class="day">Sunday</span><span class="time">Closed</span></li>
        <li><span class="day">Monday</span><span class="time">Closed</span></li>
        <li>
          <span class="day">Tuesday</span><span class="time">Closed</span>
        </li>
        <li>
          <span class="day">Wednesday</span><span class="time">10am – 6pm</span>
        </li>
        <li>
          <span class="day">Thursday</span><span class="time">10am – 6pm</span>
        </li>
        <li>
          <span class="day">Friday</span><span class="time">10am – 6pm</span>
        </li>
        <li>
          <span class="day">Saturday</span><span class="time">10am – 5pm</span>
        </li>
      </ul>
      <div class="closure-notice">
        <img class="pointing-hand" src="/PointingHand.png" />
        <strong
          >We will be closed July 4–14 <br /> for maintenance and repairs. <br
          />We will reopen July 15th.</strong
        >
      </div>
    </div>

    <!-- <form class="contact-form">
      <h4>We're Here to Help!</h4>
      <input type="text" placeholder="Name*" required />
      <input type="email" placeholder="Email*" required />
      <textarea rows="4" placeholder="Message*" required></textarea>
      <button type="submit">Send</button>
    </form> -->
  </div>

  <div class="bottom-row">
    <img src={`${base}/images/BowtieCharlie.jpg`} alt="Popcorn Charlie" />

    <div class="special-orders" id="special-orders">
      <h4>We take requests!</h4>
      <p>
        If you want a flavor that is out of season or only available upon
        request, we will make it for you! The only catch is you have to meet a
        minimum purchase amount:
        <ul>
          <li>3 gallons per single flavor/color</li>
          <li>10 gallons for custom combos</li>
        </ul>
      </p>

      <h4>100% Satisfaction Guaranteed</h4>
      <p>
        Our popcorn is guaranteed fresh for one month after the packaged date.
        We want you to be completely satisfied, so if you experience any issues
        with the product, please contact us right away so we can make it right.
      </p>
    </div>
  </div>
</section>

<style>
  .contact-row {
    padding: 48px 32px 24px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-row h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .contact-row h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 20px 0 6px;
  }

  .contact-row h4.name {
    font-size: 1.6rem;
  }

  .contact-row p {
    line-height: 1.65;
  }

  .hours-list {
    list-style: none;
    padding: 0;
    margin: 8px auto 0;
    display: inline-block;
    text-align: left;
  }

  .hours-list li {
    display: flex;
    gap: 16px;
    line-height: 1.8;
  }

  .hours-list .day {
    width: 100px;
    font-weight: 600;
  }

  .hours-list .time {
    color: #555;
  }

  .contact-row strong {
    font-family: "Lithos Pro Black", "Phosphate", "Bebas Neue", Impact, serif;
    font-weight: 900;
    font-size: 2rem;
    color: red;
  }

  @keyframes bounce-right {
    0%,
    100% {
      transform: translateY(-50%) translateX(0);
    }
    50% {
      transform: translateY(-50%) translateX(14px);
    }
  }

  .closure-notice {
    position: relative;
    text-align: center;
    overflow: visible;
  }

  .pointing-hand {
    position: absolute;
    height: 9.5rem;
    width: auto;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    margin-right: -4rem;
    animation: bounce-right 1.4s ease-in-out infinite;
  }

  .contact-info a {
    display: inline-block;
    margin-top: 6px;
    font-weight: 600;
  }

  .bottom-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    padding: 24px 32px 48px;
    gap: 32px;
  }

  .bottom-row > img {
    width: 300px;
    height: auto;
    margin: 0 auto;
  }

  .special-orders {
    width: 50%;
  }

  .special-orders h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 20px 0 6px;
  }

  .special-orders p,
  .special-orders li {
    line-height: 1.65;
  }

  .special-orders ul {
    padding-left: 20px;
    margin-top: 8px;
  }

  .special-orders li {
    margin-bottom: 4px;
  }

  @media (max-width: 640px) {
    .bottom-row {
      flex-direction: column;
      padding: 16px 16px 32px;
    }

    .bottom-row > img {
      width: 100%;
      margin: 0;
    }

    .special-orders {
      width: 100%;
    }

    .contact-row {
      padding: 24px 16px 16px;
    }

    .contact-row strong {
      font-size: 1rem;
      text-align: right;
      display: block;
    }

    .closure-notice {
      padding: 32px 0 16px;
    }

    .pointing-hand {
      height: 4rem;
      margin-right: -6rem;
    }
  }
</style>
