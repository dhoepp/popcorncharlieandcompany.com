---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="about">
  <div class="top-row">
    <img src={`${base}/images/BowtieCharlie.jpg`} alt="Popcorn Charlie" />

    <div class="contact" id="contact">
      <h2>Contact Us</h2>

      <div class="contact-info">
        <h4>"Popcorn Charlie" and Company</h4>
        <p>3601 North Division Street, Davenport, Iowa 52806, United States</p>
        <a href="tel:5633889555">563-388-9555</a>
      </div>

      <div class="contact-hours">
        <h4>Hours</h4>
        <p>Open W-F: 10:00 am – 06:00 pm (10-5 Saturday)</p>
      </div>

      <!-- <form class="contact-form">
        <h4>We're Here to Help!</h4>
        <input type="text" placeholder="Name*" required />
        <input type="email" placeholder="Email*" required />
        <textarea rows="4" placeholder="Message*" required></textarea>
        <button type="submit">Send</button>
      </form> -->
    </div>
  </div>

  <div class="bottom-row" id="special-orders">
    <h4>Personalized Service:</h4>
    <p>
      We also take special requests. If you want a flavor that is out of season
      or only available upon request, we will make it for you! The only catch
      is: you have to meet a minimum purchase amount:
    </p>
    <ul>
      <li>$20 for Savory Flavors</li>
      <li>$30 for Candied Flavors</li>
      <li>$35 for Candied+ Flavors</li>
      <li>$40 for Premium Candied Flavors</li>
    </ul>

    <h4>Committed to Quality</h4>
    <p><!-- content to be filled in --></p>

    <h4>100% Satisfaction Guaranteed</h4>
    <p>
      Our popcorn is guaranteed fresh for one month after the packaged date. We
      want you to be completely satisfied, so if you experience any issues with
      the product, please contact us right away so we can address the problem.
    </p>
  </div>
</section>

<style>
  .top-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    padding: 48px 32px 24px;
    gap: 32px;
  }

  .top-row > img {
    width: 50%;
    height: auto;
  }

  .contact {
    width: 50%;
  }

  .bottom-row {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 32px 48px;
    text-align: center;
  }

  .contact h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .contact h4,
  .bottom-row h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 20px 0 6px;
  }

  .contact p,
  .bottom-row p,
  .bottom-row li {
    line-height: 1.65;
  }

  .bottom-row ul {
    list-style: none;
    padding: 0;
    margin-top: 8px;
  }

  .bottom-row li {
    margin-bottom: 4px;
  }

  .contact-info a {
    display: inline-block;
    margin-top: 6px;
    font-weight: 600;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 24px;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.95rem;
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form button {
    align-self: flex-start;
    padding: 10px 28px;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .contact-form button:hover {
    opacity: 0.8;
  }
</style>
