      <input type="text" placeholder="Name*" required />
      <input type="email" placeholder="Email*" required />
      <textarea rows="4" placeholder="Message*" required></textarea>
      <button type="submit">Send</button>
    </form>
  </div>
</section>

<style>
  .about-contact {
    display: flex;
    flex-direction: row;
    gap: 32px;
    align-items: flex-start;
  }

  .about,
  .contact {
    flex: 1;
  }

  .about img {
    width: 400px;
    max-width: 100%;
    height: auto;
  }
</style>
